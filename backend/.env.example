# Fly secret: runtime role microsched_app (CRUD only; never use an owner URL here).
DATABASE_URL=postgresql://microsched_app:password@host/database?sslmode=require

# Local only: schema owner used by Alembic; never upload this URL to Fly.
NEON_MIGRATOR_URL=postgresql://microsched_migrator:password@host/database?sslmode=require

# Local bootstrap only: Neon owner; never upload this URL to Fly or runtime code.
NEON_OWNER_URL=postgresql://neondb_owner:password@host/database?sslmode=require


# --- Auth (007) ---
# OAuth client "microSched web" (Google Cloud Console, External/Testing).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Danh sách email được phép đăng nhập, phân tách bằng dấu phẩy, so sánh lowercase.
ALLOWED_EMAILS=
# CHỈ để ký cookie state/nonce tạm trong lúc handshake OAuth — KHÔNG phải session
# đăng nhập (session = opaque token + bảng `session`, auth-brief §2).
# Sinh: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Local và Fly nên để hai giá trị KHÁC nhau.
OAUTH_STATE_SECRET=

# --- Mã hóa cột (008a) ---
# Master key AES-GCM cho các cột 🔐 (schema-physical-brief §7.1 + K18, prefix enc:v1:).
# Sinh: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
#
# ⚠️⚠️ MẤT KHÓA NÀY = MẤT VĨNH VIỄN toàn bộ tracker/subscription/entry + mọi
# note/task private. Không có đường khôi phục — không backdoor, không reset, không
# hỗ trợ nhà cung cấp. Neon giữ ciphertext; khóa chỉ nằm ở nơi BẠN cất.
# Trước khi ghi dòng dữ liệu mã hóa ĐẦU TIÊN, cất khóa theo đúng
# db-and-data-model-brief.md §6 — BA nơi phân vai:
#   1. password manager  (bản chính, tra cứu nhanh)
#   2. note trên điện thoại  (dự phòng tiện tay)
#   3. USB offline  (last-resort, không cắm thường xuyên)
# Không nơi nào trùng domain với Google Drive (nơi giữ dump) — mất Drive không
# kéo theo mất khóa. Mất CẢ BA mới mất khả năng giải mã.
# Fly secrets KHÔNG phải bản backup — đó là bản đang chạy.
ENCRYPTION_MASTER_KEY=
